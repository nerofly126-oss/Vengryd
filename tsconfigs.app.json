{
  "extends": "./tsconfigs.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfigs.app.tsbuildinfo",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "types": ["vite/client"]
  },
  "include": ["src"]
}
